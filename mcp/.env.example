# SkillYard MCP server configuration
# Copy this file to .env and set values for your environment

# Port the HTTP server listens on
PORT=3333

# Public base URL of this server — used to generate download URLs returned to agents
# Set this to your externally reachable URL when deployed remotely
# Default: http://localhost:<PORT>
BASE_URL=http://localhost:3333

# Absolute path to the skills directory
# Default: .agents/skills/ relative to the repo root
# SKILLYARD_DIR=/absolute/path/to/skills

# SQLite index (skills + FTS + feedback). Created on first run.
# STORAGE_BACKEND=sqlite
# SKILLYARD_DB_PATH=./skillyard.db

# Dev-only: enables POST /feedback/test for smoke tests. NEVER in production.
# SKILLYARD_DEV_MODE=true
